# PostgreSQL connection string.
# Locally: point this at a local Postgres instance (e.g. via `npx prisma dev`) or a free cloud Postgres.
# On Railway: add a PostgreSQL plugin to your project and Railway will expose DATABASE_URL automatically;
# reference it in this service as ${{Postgres.DATABASE_URL}} in the Railway dashboard.
DATABASE_URL="postgresql://user:password@localhost:5432/memorials?schema=public"
